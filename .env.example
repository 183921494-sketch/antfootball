# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (可选，用于AI分析)
OPENAI_API_KEY=your_openai_api_key

# 系统配置
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=蚂蚁足球

# 佣金配置
COMMISSION_RATE_LOTTERY_LOW=0.10
COMMISSION_RATE_LOTTERY_MID=0.08
COMMISSION_RATE_LOTTERY_HIGH=0.06

COMMISSION_RATE_PLATFORM_LOW=0.15
COMMISSION_RATE_PLATFORM_MID=0.12
COMMISSION_RATE_PLATFORM_HIGH=0.10

# 环境
NODE_ENV=development
